datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ======================================================
// ENUMS
// ======================================================

enum Currency {
  SYP
  USD
}

enum RequestType {
  internal
  external
}

enum Priority {
  low
  medium
  high
  emergency
}

enum RequestStatus {
  new
  accepted
  ontheway
  arrived
  underrepair
  completed
  incompleted
  pulltocenter
  postponed
  cancelled
  notanswer
  notrepairable
  repeated
}

enum MovementType {
  supply
  issue
  adjust
  return
}

// ======================================================
// MODELS
// ======================================================

model User {
  id           String    @id @default(uuid()) @db.Char(36)
  userNumber   String    @unique @map("user_number") @db.VarChar(50)
  profileImagePath           String?  @map("profile_image_path") @db.VarChar(500)
  documentImagePath           String?  @map("document_image_path") @db.VarChar(500)
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  fullName     String    @map("full_name") @db.VarChar(255)
  jobTitle             String?    @map("job_title") @db.VarChar(255)
  roleId       String    @map("role_id") @db.Char(36)
  phone        String    @db.VarChar(50)
  salary       Decimal   @default(0.00) @db.Decimal(12, 2)
  isActive     Boolean   @default(true) @map("is_active")
  tokenDevice  String    @map("token_device") @db.Text
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamp(0)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  // Relationships
  role                  Role                       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  refreshTokens         RefreshToken[]
  inventories           TechnicianDailyInventory[]
  createdRequests       Request[]                  @relation("CreatedByRequests")
  assignedTechnicians   TechnicianAssignment[]     @relation("TechnicianAssignments")
  assignedByAssignments TechnicianAssignment[]     @relation("AssignedByAssignments")
  statusChanges         RequestStatusHistory[]     @relation("ChangedByHistory")
  invoices              Invoice[]
  movements             InventoryMovement[]
  notifications         Notification[]

  @@index([userNumber], map: "idx_user_number")
  @@index([email], map: "idx_email")
  @@index([roleId], map: "idx_role_id")
  @@index([isActive], map: "idx_is_active")
  @@map("users")
}

model Role {
  id        String   @id @default(uuid()) @db.Char(36)
  name      String   @unique @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  users     User[]

  @@map("roles")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Char(36)
  userId    String   @map("user_id") @db.Char(36)
  token     String   @db.Text
  expiresAt DateTime @map("expires_at") @db.DateTime(0)
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(0)
  isBlocked Boolean  @default(false) @map("isblocked")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_user_id")
  @@index([expiresAt], map: "idx_expires_at")
  @@index([isBlocked], map: "idx_isblocked_at")
  @@map("refresh_tokens")
}

model TechnicianDailyInventory {
  id            String   @id @default(uuid()) @db.Char(36)
  technicianId  String   @map("technician_id") @db.Char(36)
  notes         String?  @db.Text
  toolsGiven    String   @map("tools_given") @db.Text
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  technician User @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@index([technicianId], map: "idx_technician_id")
  @@map("technician_daily_inventory")
}

model CenterSettings {
  id                 String   @id @default(uuid()) @db.Char(36)
  centerName         String   @map("center_name") @db.VarChar(255)
  secondaryName      String?   @map("secondary_name") @db.VarChar(255)
  address            String   @db.Text
  phone1             String   @db.VarChar(50)
  phone2             String?   @db.VarChar(50)
  email              String   @db.VarChar(255)
  term1              String?  @db.Text
  term2              String?  @db.Text
  term3              String?  @db.Text
  term4              String?  @db.Text
  logoPath           String?  @map("logo_path") @db.VarChar(500)
  dollarExchangeRate Decimal  @default(140) @map("dollar_exchange_rate") @db.Decimal(12, 4)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  @@index([centerName], map: "idx_center_name")
  @@index([phone1], map: "idx_phone1")
  @@index([email], map: "idx_email")
  @@map("center_settings")
}

model Customer {
  id             String    @id @default(uuid()) @db.Char(36)
  customerNumber String    @unique @map("customer_number") @db.VarChar(50)
  name           String    @db.VarChar(255)
  firstPhone     String    @unique @map("firstphone") @db.VarChar(50)
  secondPhone    String?   @unique @map("secondphone") @db.VarChar(50)
  address        String?   @db.Text
  locationLink   String?   @map("location_link") @db.Text
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  requests       Request[]

  @@index([customerNumber], map: "idx_customer_number")
  @@index([firstPhone], map: "idx_firstphone")
  @@index([secondPhone], map: "idx_secondphone")
  @@index([name], map: "idx_name")
  @@index([isActive], map: "idx_is_active")
  @@map("customers")
}

model Request {
  id               String        @id @default(uuid()) @db.Char(36)
  requestNumber    String        @unique @map("request_number") @db.VarChar(50)
  type             RequestType   @map("type")
  customerId       String        @map("customer_id") @db.Char(36)
  priority         Priority      @default(medium)
  faultDescription String        @map("fault_description") @db.Text
  notes            String?       @db.Text
  scheduledDate    DateTime?      @map("scheduled_date") @db.Date
  scheduledTime    DateTime?     @map("scheduled_time") @db.Time(0)
  isRepeated       Boolean       @default(false) @map("is_repeated")
  isCompleted      Boolean       @default(false) @map("is_completed")
  status           RequestStatus @default(new)
  createdBy        String        @map("created_by") @db.Char(36)
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamp(0)

  customer      Customer               @relation(fields: [customerId], references: [id], onDelete: Restrict)
  creator       User                   @relation("CreatedByRequests", fields: [createdBy], references: [id], onDelete: Restrict)
  assignments   TechnicianAssignment[]
  devices       RequestDevice[]
  voiceRecords  RequestVoiceRecord[]
  statusHistory RequestStatusHistory[]
  invoice       Invoice?

  @@index([requestNumber], map: "idx_request_number")
  @@index([customerId], map: "idx_customer_id")
  @@index([status], map: "idx_status")
  @@index([type], map: "idx_type")
  @@index([isCompleted], map: "idx_is_completed")
  @@index([priority], map: "idx_priority")
  @@index([scheduledDate], map: "idx_scheduled_date")
  @@index([createdAt], map: "idx_created_at")
  @@map("requests")
}

model RequestStatusHistory {
  id        String        @id @default(uuid()) @db.Char(36)
  requestId String        @map("request_id") @db.Char(36)
  status    RequestStatus
  changedAt DateTime      @default(now()) @map("changed_at") @db.Timestamp(0)
  changedBy String?       @map("changed_by") @db.Char(36)
  notes                  String?  @db.Text

  changer User?   @relation("ChangedByHistory", fields: [changedBy], references: [id], onDelete: Restrict)
  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId], map: "idx_request_id")
  @@index([status], map: "idx_status")
  @@index([changedAt], map: "idx_changed_at")
  @@map("request_status_history")
}

model RequestDevice {
  id         String   @id @default(uuid()) @db.Char(36)
  requestId  String   @map("request_id") @db.Char(36)
  deviceType String   @map("device_type") @db.VarChar(100)
  deviceName String   @map("device_name") @db.VarChar(255)
  brand      String?  @db.VarChar(100)
  model      String?  @db.VarChar(100)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId], map: "idx_request_id")
  @@map("request_devices")
}

model RequestVoiceRecord {
  id           String   @id @default(uuid()) @db.Char(36)
  requestId    String   @map("request_id") @db.Char(36)
  fullFilePath String   @map("full_file_path") @db.VarChar(500)
  fileSize     Int?     @map("file_size")
  mimeType     String?  @map("mime_type") @db.VarChar(100)
  duration     Int?     @db.Int
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId], map: "idx_request_id")
  @@index([createdAt], map: "idx_request_voice_record_created_at")
  @@map("request_voice_records")
}

model TechnicianAssignment {
  id           String   @id @default(uuid()) @db.Char(36)
  requestId    String   @map("request_id") @db.Char(36)
  technicianId String   @map("technician_id") @db.Char(36)
  isActive     Boolean  @default(true) @map("is_active")
  assignedBy   String   @map("assigned_by") @db.Char(36)
  assignedAt   DateTime @default(now()) @map("assigned_at") @db.Timestamp(0)

  request    Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  technician User    @relation("TechnicianAssignments", fields: [technicianId], references: [id], onDelete: Restrict)
  assigner   User    @relation("AssignedByAssignments", fields: [assignedBy], references: [id], onDelete: Restrict)

  @@unique([requestId, technicianId], map: "unique_request_technician")
  @@index([requestId], map: "idx_request_id")
  @@index([technicianId], map: "idx_technician_id")
  @@map("technician_assignments")
}

model SparePart {
  id              String              @id @default(uuid()) @db.Char(36)
  sparePartNumber String              @unique @map("spare_part_number") @db.VarChar(50)
  name            String              @db.VarChar(255)
  shelf_location  String?             @unique @db.VarChar(100)
  sku             String?             @unique @db.VarChar(100)
  quantity        Int                 @default(0)
  costSyp         Decimal             @default(0.00) @map("cost_syp") @db.Decimal(12, 2)
  costUsd         Decimal             @default(0.00) @map("cost_usd") @db.Decimal(10, 2)
  isActive        Boolean             @default(true) @map("is_active")
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt       DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  invoiceItems    InvoiceItem[]
  movements       InventoryMovement[]

  @@index([sparePartNumber], map: "idx_spare_part_number")
  @@index([sku], map: "idx_sku")
  @@index([name], map: "idx_name")
  @@index([isActive], map: "idx_is_active")
  @@map("spare_parts")
}

model Invoice {
  id                     String   @id @default(uuid()) @db.Char(36)
  invoiceNumber          String   @unique @map("invoice_number") @db.VarChar(50)
  requestId              String   @map("request_id") @db.Char(36)
  technicianId           String   @map("technician_id") @db.Char(36)
  type                   String   @db.VarChar(20) // 'external', 'internal'
  status                 String   @default("paid_partial") @db.VarChar(20) // 'paid_full', 'paid_partial', 'refunded'
  totalAmount            Decimal  @default(0.00) @map("total_amount") @db.Decimal(12, 2)
  totalCurrency          Currency @default(SYP) @map("total_currency")
  paidAmount             Decimal  @default(0.00) @map("paid_amount") @db.Decimal(12, 2)
  remainingAmount        Decimal  @default(0.00) @map("remaining_amount") @db.Decimal(12, 2)
  warrantyPeriod         String?  @map("warranty_period") @db.VarChar(50)
  needsCenterMaintenance String?  @map("needs_center_maintenance") @db.Text
  notes                  String?  @db.Text
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt              DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  request    Request       @relation(fields: [requestId], references: [id], onDelete: Restrict)
  technician User          @relation(fields: [technicianId], references: [id], onDelete: Restrict)
  items      InvoiceItem[]
  payments   Payment[]

  @@unique([requestId], map: "unique_request_id")
  @@index([invoiceNumber], map: "idx_invoice_number")
  @@index([requestId], map: "idx_request_id")
  @@index([technicianId], map: "idx_technician_id")
  @@index([status], map: "idx_status")
  @@index([type], map: "idx_type")
  @@map("invoices")
}

model InvoiceItem {
  id          String    @id @default(uuid()) @db.Char(36)
  invoiceId   String    @map("invoice_id") @db.Char(36)
  sparePartId String    @map("spare_part_id") @db.Char(36)
  quantity    Int       @default(1)
  unitPrice   Decimal   @map("unit_price") @db.Decimal(12, 2)
  currency    Currency  @default(SYP) // 'SYP', 'USD'
  totalPrice  Decimal   @default(dbgenerated()) @map("total_price") @db.Decimal(12, 2)
  invoice     Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  sparePart   SparePart @relation(fields: [sparePartId], references: [id], onDelete: Restrict)

  @@index([invoiceId], map: "idx_invoice_id")
  @@index([sparePartId], map: "idx_spare_part_id")
  @@map("invoice_items")
}

model Payment {
  id                 String   @id @default(uuid()) @db.Char(36)
  invoiceId          String   @map("invoice_id") @db.Char(36)
  amount             Decimal  @db.Decimal(12, 2)
  currency           Currency  @default(SYP) // 'SYP', 'USD'
  paymentMethod      String   @map("payment_method") @db.VarChar(20) // 'cash', 'sham_cash'
  dollarExchangeRate Decimal  @map("dollar_exchange_rate") @db.Decimal(12, 4)
  convertedAmount    Decimal  @map("converted_amount") @db.Decimal(12, 2)
  paidAt             DateTime @default(now()) @map("paid_at") @db.Timestamp(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  @@index([invoiceId], map: "idx_invoice_id")
  @@index([paidAt], map: "idx_paid_at")
  @@index([currency], map: "idx_currency")
  @@index([paymentMethod], map: "idx_payment_method")
  @@map("payments")
}

model InventoryMovement {
  id           String       @id @default(uuid()) @db.Char(36)
  movementNo   String       @unique @map("movement_no") @db.VarChar(50)
  partId       String       @map("part_id") @db.Char(36)
  movementType MovementType @map("movement_type")

  responsibleBy String   @map("responsible_by")
  responsibleId String?  @map("responsible_id") @db.Char(36)
  reference     String?  @db.VarChar(100)
  movementDate  DateTime @default(now()) @map("movement_date") @db.Timestamp(0)
  quantity      Int      @default(1)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  part        SparePart @relation(fields: [partId], references: [id])
  responsible User?     @relation(fields: [responsibleId], references: [id])

  @@index([movementNo], map: "idx_movement_no")
  @@index([partId], map: "idx_part")
  @@index([movementDate], map: "idx_movement_date")
  @@index([movementType], map: "idx_movement_type")
  @@map("inventory_movements")
}

model Expense {
  id        String   @id @default(uuid()) @db.Char(36)
  type      String   @db.VarChar(20) // 'fixed', 'variable', 'other'
  name      String   @db.VarChar(100)
  amount    Decimal  @db.Decimal(12, 2)
  month     Int?
  year      Int?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  @@index([type], map: "idx_type")
  @@index([month, year], map: "idx_month_year")
  @@index([createdAt], map: "idx_created_at")
  @@map("expenses")
}

model Notification {
  id        String    @id @default(uuid()) @db.Char(36)
  userId    String    @map("user_id") @db.Char(36)
  title     String    @db.VarChar(255)
  body      String    @db.Text
  isRead    Boolean   @default(false) @map("is_read")
  readAt    DateTime? @map("read_at") @db.Timestamp(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_user_id")
  @@index([isRead], map: "idx_is_read")
  @@index([createdAt], map: "idx_created_at")
  @@map("notifications")
}

